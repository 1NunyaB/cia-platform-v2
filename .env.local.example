# Copy to .env.local and fill in values from your Supabase project and OpenAI.

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: optional service role for admin scripts (not required for normal app flow if RLS is sufficient)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI — required for AI analysis route
OPENAI_API_KEY=sk-your-openai-key

# Optional: default model for structured extraction
OPENAI_MODEL=gpt-4o-mini

# Optional: absolute site URL for invite links (otherwise the API uses the request Origin header)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
